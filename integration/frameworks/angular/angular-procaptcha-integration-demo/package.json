{
	"name": "@prosopo/angular-procaptcha-integration-demo",
	"version": "1.1.90",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"type": "module",
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "tsc --build --verbose tsconfig.cjs.json",
		"build:bundle": "",
		"build:bundle:es": "",
		"build:bundle:iife": "",
		"build:bundle:webpack": "NODE_ENV=${NODE_ENV:-development}; MODE=${MODE:-$NODE_ENV}; webpack build --config webpack.config.cjs --mode $MODE",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"ng": "ng",
		"start": "ng serve",
		"watch": "ng build --watch --configuration development",
		"dev": "npm run start"
	},
	"dependencies": {
		"@angular/common": "20.3.25",
		"@angular/core": "20.3.25",
		"@angular/platform-browser": "20.3.25",
		"@angular/router": "20.3.25",
		"@prosopo/angular-procaptcha-wrapper": "1.1.90"
	},
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@angular-builders/custom-webpack": "20.0.0",
		"@angular-devkit/build-angular": "20.3.28",
		"@angular/cli": "20.3.25",
		"@angular/compiler-cli": "20.3.25",
		"@types/jasmine": "5.1.15",
		"@types/node": "22.10.2",
		"del-cli": "6.0.0",
		"dotenv-webpack": "8.1.0",
		"jasmine-core": "5.6.0",
		"karma": "6.4.4",
		"karma-chrome-launcher": "3.2.0",
		"karma-jasmine": "5.1.0",
		"karma-jasmine-html-reporter": "2.1.0",
		"typescript": "5.8.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "integration/frameworks/angular/angular-procaptcha-integration-demo"
	}
}
