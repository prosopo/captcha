{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [
		"**/.env.*",
		"package.json",
		"package-lock.json",
		"tsconfig.json",
		"tsconfig.*.json",
		"vite.config.*",
		"vite.*.config.*"
	],
	"globalEnv": ["NODE_ENV"],
	"ui": "tui",
	"concurrency": "100%",
	"daemon": false,
	"envMode": "loose",
	"tasks": {
		"build": {
			"dependsOn": ["^build", "@prosopo/config#build"],
			"outputs": ["dist/vite/esm/**"]
		},
		"build:esm": {
			"dependsOn": ["^build:esm", "@prosopo/config#build"],
			"outputs": ["dist/vite/esm/**"]
		},
		"build:cjs": {
			"dependsOn": ["^build:cjs", "@prosopo/config#build"],
			"outputs": ["dist/vite/cjs/**"]
		},
		"build:types": {
			"dependsOn": ["^build:types"],
			"outputs": ["dist/types/**", "*.tsbuildinfo"]
		},
		"build:tsc": {
			"dependsOn": ["^build:tsc"],
			"outputs": ["dist/tsc/esm/**", "*.tsbuildinfo"]
		},
		"build:tsc:esm": {
			"dependsOn": ["^build:tsc:esm"],
			"outputs": ["dist/tsc/esm/**", "*.tsbuildinfo"]
		},
		"build:tsc:cjs": {
			"dependsOn": ["^build:tsc:cjs"],
			"outputs": ["dist/tsc/cjs/**", "*.tsbuildinfo"]
		},
		"build:bundle": {
			"dependsOn": ["@prosopo/config#build"],
			"outputs": ["dist/bundle/es/**"]
		},
		"build:bundle:es": {
			"dependsOn": ["@prosopo/config#build"],
			"outputs": ["dist/bundle/es/**"]
		},
		"build:bundle:iife": {
			"dependsOn": ["@prosopo/config#build"],
			"outputs": ["dist/bundle/iife/**"]
		},
		"build:bundle:webpack": {
			"dependsOn": ["@prosopo/config#build"],
			"outputs": ["dist/bundle/webpack/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"test": {
			"dependsOn": ["@prosopo/config#build"]
		},
		"lint": { "dependsOn": ["^lint"] },
		"clean": {
			"cache": false
		},
		"clean:deps": {
			"dependsOn": ["clean", "^clean"],
			"cache": false
		}
	},
	"remoteCache": {
		"enabled": false
	}
}
