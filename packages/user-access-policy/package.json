{
	"name": "@prosopo/user-access-policy",
	"version": "3.10.9",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/.export.d.ts",
			"import": "./dist/vite/esm/.export.js",
			"require": "./dist/vite/cjs/.export.cjs"
		},
		"./api": {
			"types": "./dist/types/api/.export.d.ts",
			"import": "./dist/vite/esm/api/.export.js",
			"require": "./dist/vite/cjs/api/.export.cjs"
		},
		"./redis": {
			"types": "./dist/types/redis/.export.d.ts",
			"import": "./dist/vite/esm/redis/.export.js",
			"require": "./dist/vite/cjs/redis/.export.cjs"
		},
		"./mongoose": {
			"types": "./dist/types/mongoose/.export.d.ts",
			"import": "./dist/vite/esm/mongoose/.export.js",
			"require": "./dist/vite/cjs/mongoose/.export.cjs"
		}
	},
	"imports": {
		"#policy/*": "./dist/*"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "tsc --build --verbose tsconfig.json",
		"build:bundle": "echo \"@prosopo/user-access-policy: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/user-access-policy: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/user-access-policy: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/user-access-policy: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"test:unit": "NODE_ENV=${NODE_ENV:-test}; TEST_TYPE=unit npx vitest run --config ./vite.test.config.ts",
		"test:integration": "NODE_ENV=${NODE_ENV:-test}; NX_PARALLEL=1 TEST_TYPE=integration npx vitest run --config ./vite.test.config.ts",
		"test": "npm run test:unit && npm run test:integration"
	},
	"dependencies": {
		"@prosopo/api": "3.5.6",
		"@prosopo/api-route": "2.6.49",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/redis-client": "1.0.26",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@redis/search": "5.0.0",
		"cidr-calc": "1.0.4",
		"dotenv": "16.4.5",
		"ip-address": "10.0.1",
		"redis": "5.0.0",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@prosopo/util-crypto": "13.5.30",
		"@types/node": "22.10.2",
		"mongoose": "8.13.0",
		"vite": "6.4.1",
		"vitest": "3.2.6",
		"yargs": "17.7.2"
	},
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/user-access-policy"
	}
}
