{
	"name": "@prosopo/api-express-router",
	"version": "3.1.32",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "tsc --build --verbose tsconfig.json",
		"build:bundle": "echo \"@prosopo/api-express-router: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/api-express-router: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/api-express-router: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/api-express-router: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts"
	},
	"dependencies": {
		"@polkadot/util": "13.5.7",
		"@prosopo/api-route": "2.6.49",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/env": "3.6.1",
		"@prosopo/locale": "3.2.5",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/util-crypto": "13.5.30",
		"dotenv": "16.4.5",
		"express": "4.21.2",
		"i18next": "24.1.0",
		"uuid": "14.0.1",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"vitest": "3.2.4"
	},
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/api-express-router"
	}
}
