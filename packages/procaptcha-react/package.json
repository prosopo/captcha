{
	"name": "@prosopo/procaptcha-react",
	"version": "2.9.79",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"main": "dist/vite/esm/index.js",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs",
			"types": "./dist/types/index.d.ts"
		}
	},
	"types": "dist/types/index.d.ts",
	"source": "./src/index.ts",
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "tsc --build --verbose tsconfig.json",
		"build:bundle": "echo \"@prosopo/procaptcha-react: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/procaptcha-react: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/procaptcha-react: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/procaptcha-react: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json"
	},
	"browserslist": [
		"> 0.5%, last 2 versions, not dead"
	],
	"dependencies": {
		"@prosopo/common": "3.1.41",
		"@prosopo/locale": "3.2.5",
		"@prosopo/procaptcha": "2.10.40",
		"@prosopo/procaptcha-common": "2.11.1",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/widget-skeleton": "2.8.4",
		"csstype": "3.1.3",
		"react": "18.3.1",
		"react-dom": "18.3.1"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@emotion/react": "11.11.1",
		"@types/node": "22.10.2",
		"@types/react-dom": "18.3.1",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/procaptcha-react"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"description": "",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	}
}
