{
	"name": "@prosopo/procaptcha-bundle",
	"version": "4.1.20",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"main": "dist/vite/esm/index.js",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		},
		"./components": {
			"types": "./dist/types/components.d.ts",
			"import": "./dist/vite/esm/components.js",
			"require": "./dist/vite/cjs/components.cjs"
		}
	},
	"types": "dist/types/index.d.ts",
	"source": "./src/index.tsx",
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "tsc --build --verbose tsconfig.cjs.json",
		"build:bundle": "npm run build:bundle:es",
		"build:bundle:es": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.config.ts --mode $NODE_ENV",
		"build:bundle:iife": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.iife.config.ts --mode $NODE_ENV",
		"build:bundle:webpack": "NODE_ENV=${NODE_ENV:-development}; MODE=${MODE:-$NODE_ENV}; webpack build --config webpack.config.cjs --mode $MODE",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"start": "NODE_ENV=${NODE_ENV:-development}; vite serve --mode $NODE_ENV --host",
		"serve": "NODE_ENV=${NODE_ENV:-development}; vite serve --config vite.serve.config.ts --mode $NODE_ENV --host",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts"
	},
	"browserslist": [
		"> 0.5%, last 2 versions, not dead"
	],
	"dependencies": {
		"@prosopo/dotenv": "3.0.46",
		"@prosopo/locale": "3.2.5",
		"@prosopo/procaptcha-common": "2.11.1",
		"@prosopo/procaptcha-frictionless": "2.12.1",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/widget-skeleton": "2.8.4",
		"dotenv": "16.4.5",
		"fast-glob": "3.3.2",
		"jsdom": "25.0.0",
		"react": "18.3.1",
		"@emotion/cache": "11.11.0",
		"@emotion/react": "11.11.1",
		"react-dom": "18.3.1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/procaptcha-bundle"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"description": "",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/jsdom": "21.1.7",
		"@types/node": "22.10.2",
		"@types/react": "18.3.1",
		"@types/react-dom": "18.3.1",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"overrides": {
		"@types/react": "18.3.1"
	}
}
