{
	"name": "@prosopo/detector",
	"version": "3.5.1",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/detector: no tsc cjs build (ESM-first codebase; CommonJS tsc compile is not viable — use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/detector: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/detector: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/detector: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/detector: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json"
	},
	"type": "module",
	"dependencies": {
		"@prosopo/types": "4.9.0",
		"dotenv": "16.4.5"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/detector"
	}
}
