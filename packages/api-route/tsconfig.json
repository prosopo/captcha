{
	"extends": "../../tsconfig.esm.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist/tsc/esm"
	},
	"include": [
		"./src",
		"src/**/*.ts",
		"src/**/.*.ts",
		"src/**/*.tsx",
		"src/**/*.json",
		"src/**/*.d.ts"
	],
	"references": [
		{
			"path": "../../dev/config/tsconfig.json"
		},
		{
			"path": "../../packages/logger/tsconfig.json"
		}
	]
}
