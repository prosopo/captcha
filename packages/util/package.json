{
	"name": "@prosopo/util",
	"version": "3.3.2",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"private": false,
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/util: no tsc cjs build (source uses import.meta, which tsc cannot emit as CommonJS; use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/util: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/util: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/util: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/util: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"cli": "node ./dist/vite/esm/js/cli.js",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts"
	},
	"main": "dist/vite/esm/index.js",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		},
		"./lodash": {
			"types": "./dist/types/lodash.d.ts",
			"import": "./dist/vite/esm/lodash.js",
			"require": "./dist/vite/cjs/lodash.cjs",
			"default": "./dist/vite/esm/lodash.js"
		},
		"./node": {
			"types": "./dist/types/node.d.ts",
			"import": "./dist/vite/esm/node.js",
			"require": "./dist/vite/cjs/node.cjs",
			"default": "./dist/vite/esm/node.js"
		}
	},
	"types": "dist/types/index.d.ts",
	"dependencies": {
		"@noble/hashes": "1.8.0",
		"ip-address": "10.0.1",
		"lodash": "4.17.21",
		"seedrandom": "3.0.5"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/lodash": "4.17.7",
		"@types/node": "22.10.2",
		"@types/seedrandom": "3.0.8",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"dotenv": "16.4.5",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.3",
		"vitest": "3.2.6"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/util"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"description": "Utility package to house all code that is not specific to prosopo. E.g. random number generation, string manipulation, etc.",
	"sideEffects": false
}
