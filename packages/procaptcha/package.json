{
	"name": "@prosopo/procaptcha",
	"version": "2.10.40",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"main": "./dist/vite/esm/index.js",
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "tsc --build --verbose tsconfig.json",
		"build:bundle": "echo \"@prosopo/procaptcha: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/procaptcha: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/procaptcha: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/procaptcha: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		},
		"./modules/Manager": {
			"types": "./dist/types/modules/Manager.d.ts",
			"import": "./dist/vite/esm/modules/Manager.js",
			"require": "./dist/vite/cjs/modules/Manager.cjs",
			"default": "./dist/vite/esm/modules/Manager.js"
		}
	},
	"dependencies": {
		"@polkadot/util": "13.5.7",
		"@prosopo/api": "3.5.6",
		"@prosopo/common": "3.1.41",
		"@prosopo/datasets": "3.1.41",
		"@prosopo/procaptcha-common": "2.11.1",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/util-crypto": "13.5.30"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"dotenv": "16.4.5",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"keywords": [],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/procaptcha"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"description": "",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"sideEffects": false
}
