{
	"name": "@prosopo/provider",
	"version": "4.13.0",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "tsc --build --verbose tsconfig.cjs.json",
		"build:bundle": "",
		"build:bundle:es": "",
		"build:bundle:iife": "",
		"build:bundle:webpack": "",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"test:unit": "NODE_ENV=${NODE_ENV:-test}; TEST_TYPE=unit npx vitest run --config ./vite.test.config.ts",
		"test:integration": "NODE_ENV=${NODE_ENV:-test}; NX_PARALLEL=1 TEST_TYPE=integration DECISION_MACHINE_ARTIFACT_CACHE_TTL_MS=1 npx vitest run --config ./vite.threads.test.config.ts",
		"test": "npm run test:unit && npm run test:integration",
		"mnemonic": "tsx ./scripts/generateMnemonic.ts"
	},
	"dependencies": {
		"@noble/hashes": "1.8.0",
		"@polkadot/util": "13.5.7",
		"@prosopo/api": "3.5.6",
		"@prosopo/api-express-router": "3.1.32",
		"@prosopo/api-route": "2.6.49",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/database": "3.15.1",
		"@prosopo/datasets": "3.1.41",
		"@prosopo/env": "3.6.1",
		"@prosopo/ipinfo": "0.2.27",
		"@prosopo/keyring": "2.9.47",
		"@prosopo/load-balancer": "2.10.1",
		"@prosopo/redis-client": "1.0.26",
		"@prosopo/locale": "3.2.5",
		"@prosopo/types": "4.9.0",
		"@prosopo/types-database": "4.11.1",
		"@prosopo/types-env": "2.10.1",
		"@prosopo/user-access-policy": "3.10.9",
		"@prosopo/util": "3.3.2",
		"@prosopo/util-crypto": "13.5.30",
		"cron": "3.1.7",
		"express": "4.21.2",
		"express-rate-limit": "7.4.0",
		"geolib": "3.3.4",
		"i18next": "24.1.0",
		"ip-address": "10.0.1",
		"mongoose": "8.13.0",
		"prom-client": "15.1.3",
		"uuid": "14.0.1",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.5.5",
		"@types/pg": "8.16.0",
		"@types/uuid": "10.0.0",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"cors": "2.8.6",
		"del-cli": "6.0.0",
		"dotenv": "16.4.5",
		"npm-run-all": "4.1.5",
		"testcontainers": "11.11.0",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"undici": "6.27.0",
		"vite": "6.4.1",
		"vitest": "3.2.6"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/provider"
	},
	"description": "The easiest way to deploy the Prosopo contract and run the Provider node is via the [captcha repository](https://github.com/prosopo/captcha/).",
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"sideEffects": false,
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	}
}
