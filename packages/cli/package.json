{
	"name": "@prosopo/cli",
	"version": "3.6.48",
	"description": "CLI for Prosopo Provider",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/cli: no tsc cjs build (source uses import.meta, which tsc cannot emit as CommonJS; use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "npm run build:bundle:es",
		"build:bundle:es": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.config.ts --mode $NODE_ENV",
		"build:bundle:iife": "echo \"@prosopo/cli: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/cli: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts",
		"cli": "node ./dist/vite/esm/cli.js",
		"start": "node ./dist/vite/esm/cli.js --api",
		"start:admin": "node ./dist/vite/esm/cli.js --api --adminApi",
		"start:dev": "node ./dist/vite/esm/cli.js --api --dev"
	},
	"dependencies": {
		"@polkadot/types-codec": "16.4.9",
		"@prosopo/api": "3.5.6",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/dotenv": "3.0.46",
		"@prosopo/env": "3.6.1",
		"@prosopo/keyring": "2.9.47",
		"@prosopo/locale": "3.2.5",
		"@prosopo/provider": "4.13.0",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/workspace": "3.1.20",
		"cron-parser": "4.9.0",
		"dotenv": "16.4.5",
		"yargs": "17.7.2",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@polkadot-api/substrate-client": "0.1.4",
		"@types/cors": "2.8.17",
		"@types/node": "22.10.2",
		"@types/yargs": "17.0.33",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"express": "4.21.2",
		"npm-run-all": "4.1.5",
		"smoldot": "2.0.26",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"author": "Prosopo",
	"license": "Apache-2.0",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/cli"
	}
}
