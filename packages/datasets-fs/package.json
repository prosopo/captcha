{
	"name": "@prosopo/datasets-fs",
	"version": "3.0.90",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"private": false,
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/datasets-fs: no tsc cjs build (ESM-first codebase; CommonJS tsc compile is not viable — use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/datasets-fs: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/datasets-fs: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/datasets-fs: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/datasets-fs: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts",
		"cli": "node ./dist/vite/esm/cli.js"
	},
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"dependencies": {
		"@noble/hashes": "1.8.0",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/util-crypto": "13.5.30",
		"@prosopo/workspace": "3.1.20",
		"bcrypt": "6.0.0",
		"cli-progress": "3.12.0",
		"sharp": "0.33.5",
		"yargs": "17.7.2",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/bcrypt": "5.0.2",
		"@types/cli-progress": "3.11.6",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"dotenv": "16.4.5",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/datasets-fs"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"description": "Datasets for use with providers",
	"directories": {
		"test": "tests"
	},
	"sideEffects": false
}
