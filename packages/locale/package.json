{
	"name": "@prosopo/locale",
	"version": "3.2.5",
	"description": "Prosopo locale library",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		},
		"./locales/en/translation.json": {
			"types": "./dist/types/locales/en/translation.json",
			"import": "./dist/vite/esm/locales/en/translation.json",
			"require": "./dist/vite/esm/locales/en/translation.json"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/locale: no tsc cjs build (ESM-first codebase; CommonJS tsc compile is not viable — use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/locale: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/locale: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/locale: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/locale: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts"
	},
	"author": "Prosopo Limited",
	"license": "Apache-2.0",
	"dependencies": {
		"i18next": "24.2.2",
		"i18next-browser-languagedetector": "8.0.2",
		"i18next-chained-backend": "4.6.2",
		"i18next-fs-backend": "2.6.0",
		"i18next-http-backend": "3.0.2",
		"i18next-http-middleware": "3.7.4",
		"i18next-resources-to-backend": "1.2.1",
		"react-i18next": "15.4.0",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"dotenv": "16.4.5",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/locale"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"sideEffects": false
}
