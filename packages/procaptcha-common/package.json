{
	"name": "@prosopo/procaptcha-common",
	"version": "2.11.1",
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"main": "dist/vite/esm/index.js",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"types": "dist/types/index.d.ts",
	"source": "./src/index.ts",
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/procaptcha-common: no tsc cjs build (ESM-first codebase; CommonJS tsc compile is not viable — use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/procaptcha-common: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/procaptcha-common: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/procaptcha-common: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/procaptcha-common: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"test": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --config ./vite.test.config.ts",
		"test:watch": "NODE_ENV=${NODE_ENV:-test}; npx vitest --config ./vite.test.config.ts",
		"test:coverage": "NODE_ENV=${NODE_ENV:-test}; npx vitest run --coverage --config ./vite.test.config.ts"
	},
	"browserslist": [
		"> 0.5%, last 2 versions, not dead"
	],
	"dependencies": {
		"@emotion/react": "11.11.1",
		"@emotion/styled": "11.11.0",
		"@prosopo/account": "2.8.48",
		"@prosopo/load-balancer": "2.10.1",
		"@prosopo/types": "4.9.0",
		"@prosopo/widget-skeleton": "2.8.4",
		"react": "18.3.1",
		"react-dom": "18.3.1"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/jsdom": "21.1.7",
		"@types/node": "22.10.2",
		"@types/react": "18.3.1",
		"@types/react-dom": "18.3.1",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"dotenv": "16.4.5",
		"jsdom": "25.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/procaptcha-common"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"description": "",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	}
}
