{
	"name": "@prosopo/account",
	"version": "2.8.48",
	"description": "Services and Utils for Prosopo account gen and management",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		},
		"./extension/ExtensionWeb2": {
			"import": "./dist/vite/esm/extension/ExtensionWeb2.js",
			"require": "./dist/vite/cjs/extension/ExtensionWeb2.cjs",
			"default": "./dist/vite/esm/extension/ExtensionWeb2.js"
		},
		"./extension/ExtensionWeb3": {
			"import": "./dist/vite/esm/extension/ExtensionWeb3.js",
			"require": "./dist/vite/cjs/extension/ExtensionWeb3.cjs",
			"default": "./dist/vite/esm/extension/ExtensionWeb3.js"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "tsc --build --verbose tsconfig.cjs.json",
		"build:bundle": "",
		"build:bundle:es": "",
		"build:bundle:iife": "",
		"build:bundle:webpack": "",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/account"
	},
	"author": "Prosopo Limited",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"dependencies": {
		"@polkadot/extension-base": "0.62.3",
		"@polkadot/extension-dapp": "0.62.3",
		"@polkadot/extension-inject": "0.62.3",
		"@polkadot/util": "13.5.7",
		"@polkadot/util-crypto": "13.5.7",
		"@prosopo/common": "3.1.41",
		"@prosopo/fingerprint": "2.7.6",
		"@prosopo/keyring": "2.9.47",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@prosopo/util-crypto": "13.5.30"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"sideEffects": false
}
