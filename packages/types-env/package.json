{
	"name": "@prosopo/types-env",
	"version": "2.10.1",
	"description": "Types for prosopo environment",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs",
			"types": "./dist/types/index.d.ts"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "tsc --build --verbose tsconfig.cjs.json",
		"build:bundle": "echo \"@prosopo/types-env: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/types-env: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/types-env: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/types-env: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/types-env"
	},
	"author": "Prosopo Limited",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"dependencies": {
		"@prosopo/logger": "2.0.0",
		"@prosopo/keyring": "2.9.47",
		"@prosopo/types": "4.9.0",
		"@prosopo/types-database": "4.11.1"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.6"
	},
	"sideEffects": false
}
