{
	"name": "@prosopo/server",
	"version": "2.10.25",
	"description": "NodeJS package for server side communication with the prosopo captcha client",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/server: no tsc cjs build (ESM-first codebase; CommonJS tsc compile is not viable — use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/server: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/server: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/server: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/server: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/server"
	},
	"author": "PROSOPO LIMITED",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"sideEffects": false,
	"dependencies": {
		"@prosopo/api": "3.5.6",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/keyring": "2.9.47",
		"@prosopo/load-balancer": "2.10.1",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"i18next": "24.1.0"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	}
}
