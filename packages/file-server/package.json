{
	"name": "@prosopo/file-server",
	"version": "2.6.46",
	"description": "Simple static file server",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "tsc --build --verbose tsconfig.cjs.json",
		"build:bundle": "echo \"@prosopo/file-server: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/file-server: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/file-server: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/file-server: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo",
		"typecheck": "tsc --project tsconfig.types.json",
		"start": "node ./dist/vite/esm/index.js"
	},
	"dependencies": {
		"@prosopo/util": "3.3.2",
		"dotenv": "16.4.5",
		"express": "4.21.2",
		"sharp": "0.33.5"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.5.5",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"author": "Prosopo",
	"license": "Apache-2.0",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "packages/file-server"
	}
}
