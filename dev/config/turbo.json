{
	"extends": ["//"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/vite/esm/**"]
		},
		"build:esm": {
			"dependsOn": ["^build:esm"],
			"outputs": ["dist/vite/esm/**"]
		},
		"build:cjs": {
			"dependsOn": ["^build:cjs"],
			"outputs": ["dist/vite/cjs/**"]
		},
		"build:types": {
			"dependsOn": ["^build:types"],
			"outputs": ["dist/types/**", "*.tsbuildinfo"]
		},
		"build:tsc": {
			"dependsOn": ["^build:tsc"],
			"outputs": ["dist/tsc/esm/**", "*.tsbuildinfo"]
		},
		"build:tsc:esm": {
			"dependsOn": ["^build:tsc:esm"],
			"outputs": ["dist/tsc/esm/**", "*.tsbuildinfo"]
		},
		"build:tsc:cjs": {
			"dependsOn": ["^build:tsc:cjs"],
			"outputs": ["dist/tsc/cjs/**", "*.tsbuildinfo"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": ["dist/types/**", "*.tsbuildinfo"]
		},
		"test": {},
		"lint": { "dependsOn": ["^lint"] },
		"clean": {
			"cache": false
		},
		"clean:deps": {
			"dependsOn": ["clean", "^clean"],
			"cache": false
		}
	}
}
