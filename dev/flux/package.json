{
	"name": "@prosopo/flux",
	"version": "2.6.58",
	"description": "Tools for managing Flux deployment",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs"
		}
	},
	"bin": {
		"flux": "dist/vite/esm/index.js"
	},
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/flux: no tsc cjs build (source uses import.meta, which tsc cannot emit as CommonJS; use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "echo \"@prosopo/flux: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/flux: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/flux: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/flux: no webpack bundle build (not supported for this package)\"",
		"typecheck": "tsc --project tsconfig.types.json",
		"cli": "node dist/vite/esm/index.js"
	},
	"author": "Prosopo Limited",
	"license": "Apache-2.0",
	"dependencies": {
		"@noble/curves": "1.9.2",
		"@polkadot/util": "13.5.7",
		"@polkadot/util-crypto": "13.5.7",
		"@prosopo/common": "3.1.41",
		"@prosopo/logger": "2.0.0",
		"@prosopo/dotenv": "3.0.46",
		"@prosopo/util": "3.3.2",
		"openpgp": "5.11.3",
		"qs": "6.15.2",
		"socket.io-client": "4.7.5",
		"varuint-bitcoin": "1.1.2",
		"yargs": "17.7.2",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"@types/qs": "6.9.18",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "dev/flux"
	}
}
