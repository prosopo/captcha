{
	"name": "@prosopo/workspace",
	"version": "3.1.20",
	"description": "Prosopo workspace library",
	"type": "module",
	"main": "dist/vite/esm/index.js",
	"types": "dist/types/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs",
			"types": "./dist/types/index.d.ts"
		}
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "tsc --build --verbose tsconfig.json",
		"build:bundle": "echo \"@prosopo/workspace: no bundle build (not supported for this package)\"",
		"build:bundle:es": "echo \"@prosopo/workspace: no es bundle build (not supported for this package)\"",
		"build:bundle:iife": "echo \"@prosopo/workspace: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/workspace: no webpack bundle build (not supported for this package)\"",
		"clean": "del-cli --verbose dist tsconfig.tsbuildinfo"
	},
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"author": "Prosopo Limited",
	"license": "Apache-2.0",
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/node": "22.10.2",
		"del-cli": "6.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "dev/workspace"
	},
	"bugs": {
		"url": "https://github.com/prosopo/captcha/issues"
	},
	"homepage": "https://github.com/prosopo/captcha#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"sideEffects": false
}
