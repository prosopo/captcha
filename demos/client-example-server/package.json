{
	"name": "@prosopo/client-example-server",
	"version": "2.7.103",
	"description": "Backend for client-example",
	"main": "dist/vite/esm/app.js",
	"types": "dist/types/app.d.ts",
	"exports": {
		".": {
			"import": "./dist/vite/esm/index.js",
			"require": "./dist/vite/cjs/index.cjs",
			"types": "./dist/types/app.d.ts"
		}
	},
	"type": "module",
	"engines": {
		"node": "^24",
		"npm": "^11"
	},
	"scripts": {
		"build": "npm run build:esm",
		"build:esm": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.esm.config.ts --mode $NODE_ENV",
		"build:cjs": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.cjs.config.ts --mode $NODE_ENV",
		"build:types": "tsc -p tsconfig.types.json",
		"build:tsc": "npm run build:tsc:esm",
		"build:tsc:esm": "tsc --build --verbose tsconfig.json",
		"build:tsc:cjs": "echo \"@prosopo/client-example-server: no tsc cjs build (source uses import.meta, which tsc cannot emit as CommonJS; use build:cjs (vite) for CommonJS output)\"",
		"build:bundle": "npm run build:bundle:es",
		"build:bundle:es": "NODE_ENV=${NODE_ENV:-development}; vite build --config vite.config.ts --mode $NODE_ENV",
		"build:bundle:iife": "echo \"@prosopo/client-example-server: no iife bundle build (not supported for this package)\"",
		"build:bundle:webpack": "echo \"@prosopo/client-example-server: no webpack bundle build (not supported for this package)\"",
		"dev": "NODE_ENV=${NODE_ENV:-development}; vite serve --mode=$NODE_ENV --config ./vite.config.ts --host",
		"start": "NODE_ENV=${NODE_ENV:-development}; node ./dist/vite/esm/app.js",
		"start:bundle": "node ./dist/bundle/es/prosopo_client_example_server.app.bundle.js",
		"typecheck": "tsc --project tsconfig.types.json"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/prosopo/captcha.git",
		"directory": "demos/client-example-server"
	},
	"author": "PROSOPO LIMITED <info@prosopo.io>",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/prosopo/client-example-server/issues"
	},
	"homepage": "https://github.com/prosopo/client-example-server#readme",
	"dependencies": {
		"@noble/hashes": "1.8.0",
		"@polkadot/util": "13.5.7",
		"@polkadot/util-crypto": "13.5.7",
		"@prosopo/common": "3.1.41",
		"@prosopo/database": "3.15.1",
		"@prosopo/logger": "2.0.0",
		"@prosopo/dotenv": "3.0.46",
		"@prosopo/keyring": "2.9.47",
		"@prosopo/server": "2.10.25",
		"@prosopo/types": "4.9.0",
		"@prosopo/util": "3.3.2",
		"@typegoose/auto-increment": "4.13.0",
		"cors": "2.8.5",
		"express": "4.21.2",
		"jsonwebtoken": "9.0.2",
		"mongodb-memory-server": "10.3.0",
		"mongoose": "8.13.0",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@prosopo/config": "3.3.4",
		"@types/jsonwebtoken": "9.0.6",
		"@types/node": "22.10.2",
		"@vitest/coverage-v8": "3.2.4",
		"concurrently": "9.0.1",
		"del-cli": "6.0.0",
		"npm-run-all": "4.1.5",
		"tslib": "2.7.0",
		"tsx": "4.20.3",
		"typescript": "5.6.2",
		"vite": "6.4.1",
		"vitest": "3.2.4"
	}
}
